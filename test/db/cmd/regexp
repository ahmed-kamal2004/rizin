NAME=/z test i
FILE=malloc://1024
CMDS=<<EOF
w test
w Test@ 444
echo
e search.in=block
b 777
/z test i
ps ascii @ hit.string.ascii.0
ps ascii @ hit.string.ascii.1
EOF
EXPECT=<<EOF

0x00000000 4 hit.string.ascii.0
0x000001bc 4 hit.string.ascii.1
test
Test
EOF
RUN

