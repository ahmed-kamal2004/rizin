NAME=breakpoints after double ood
FILE=bins/elf/analysis/x86-helloworld-gcc
ARGS=
CMDS=<<EOF
db @ main
db @ main+3
ood > $_
dc # should hit the first breakpoint
.drf
%v eip-main
ood > $_
dc # should hit the first breakpoint
.drf
%v eip-main
dc # should hit the the second breakpoint
.drf
%v eip-main
EOF
EXPECT=<<EOF
0x0
0x0
0x3
EOF
RUN

